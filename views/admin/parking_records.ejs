<%- include('../partials/header', { title: title, user: user }) %>

<h2 class="mt-4">All Parking Records</h2>

<% if (error) { %>
    <div class="alert alert-danger" role="alert"><%= error %></div>
<% } %>

<form action="/admin/records" method="GET" class="d-flex mb-3">
    <input 
        type="text" 
        name="search" 
        placeholder="Search by Vehicle No. or Customer Name..." 
        value="<%= searchQuery %>" 
        class="form-control me-2"
    >
    <button type="submit" class="btn btn-primary">Search</button>
    <a href="/admin/records" class="btn btn-secondary ms-2">Clear</a>
</form>

<% if (records.length === 0) { %>
    <div class="alert alert-warning">No records found. Try a different search term.</div>
<% } else { %>
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th><th>Vehicle No.</th><th>Customer</th><th>Check-In</th><th>Check-Out</th><th>Spot</th><th>Fee Paid</th><th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% records.forEach(record => { %>
                <tr>
                    <td><%= record.record_id %></td>
                    <td><%= record.vehicle_number %></td>
                    <td><%= record.username %></td>
                    <td><%= new Date(record.check_in_time).toLocaleString() %></td>
                    <td>
                        <% if (record.check_out_time) { %>
                            <%= new Date(record.check_out_time).toLocaleString() %>
                        <% } else { %>
                            <span class="badge bg-success">PARKED</span> 
                        <% } %>
                    </td>
                    <td><%= record.parking_spot_id %></td>
                    
                    <td><%= record.rate_paid ? `₹${parseFloat(record.rate_paid).toFixed(2)}` : 'N/A' %></td>
                    
                    <td>
                        <form action="/admin/records/delete/<%= record.record_id %>" method="POST" style="display:inline;">
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Confirm deletion of this record?');">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </td>
                </tr>
            <% }); %>
        </tbody>
    </table>
<% } %>

<%- include('../partials/footer') %>