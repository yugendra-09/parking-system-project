<%- include('../partials/header', { title: title, user: user }) %>

<h2 class="mt-4">Daily Revenue Report</h2>

<% if (error) { %>
    <div class="alert alert-danger" role="alert"><%= error %></div>
<% } %>

<% if (revenueData.length === 0) { %>
    <div class="alert alert-info mt-3">No revenue data found for recent days (ensure you have checked out some vehicles).</div>
<% } else { %>
    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr><th>Date</th><th>Total Transactions</th><th>Total Revenue</th></tr>
        </thead>
        <tbody>
            <% revenueData.forEach(data => { %>
                <tr>
                    <td><%= new Date(data.report_date).toLocaleDateString() %></td>
                    <td><%= data.total_transactions %></td>
                    
                    <td>**₹<%= parseFloat(data.total_revenue).toFixed(2) %>**</td>
                    
                </tr>
            <% }); %>
        </tbody>
    </table>
<% } %>

<%- include('../partials/footer') %>