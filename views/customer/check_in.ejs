<%- include('../partials/header', { title: title, user: user }) %>

<h2>Vehicle Check-In</h2>

<% if (error) { %>
    <p style="color: red;"><%= error %></p>
<% } %>

<form action="/checkin" method="POST">
    <div class="form-group">
        <label for="vehicle_number">Vehicle Number (e.g., MH12AB1234)</label>
        <input type="text" id="vehicle_number" name="vehicle_number" required>
    </div>
    <div class="form-group">
        <label for="parking_spot_id">Requested Spot ID (e.g., A101)</label>
        <input type="text" id="parking_spot_id" name="parking_spot_id" required>
    </div>
    <button type="submit" class="button-primary">Check In</button>
</form>
<%- include('../partials/footer') %>