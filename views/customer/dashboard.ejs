<%- include('../partials/header', { title: title, user: user }) %>

<h2 class="mt-4">Welcome, <%= user.username %>!</h2>

<h3 class="mt-4">Your Recent Parking Records</h3>
<% if (error) { %>
    <div class="alert alert-danger" role="alert"><%= error %></div>
<% } else if (records.length === 0) { %>
    <div class="alert alert-info">
        You have no recent parking history. <a href="/checkin" class="alert-link">Check in a vehicle now!</a>
    </div>
<% } else { %>
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>Vehicle No.</th><th>Check-In</th><th>Status</th><th>Fee Paid</th><th>Action</th></tr>
        </thead>
        <tbody>
            <% records.forEach(record => { %>
                <tr>
                    <td><%= record.vehicle_number %></td>
                    <td><%= new Date(record.check_in_time).toLocaleString() %></td>
                    <td>
                        <% if (record.check_out_time) { %>
                            <span class="badge bg-secondary">Checked Out</span>
                        <% } else { %>
                            <span class="badge bg-success">Currently Parked</span>
                        <% } %>
                    </td>
                    
                    <td>
                        <% 
                            let feeDisplay = 'N/A';
                            if (record.rate_paid) {
                                // Explicitly convert and format (CRITICAL FIX)
                                feeDisplay = `₹${parseFloat(record.rate_paid).toFixed(2)}`;
                            }
                        %>
                        <%= feeDisplay %>
                    </td>
                    
                    <td>
                        <% if (!record.check_out_time) { %>
                            <a href="/checkout/<%= record.record_id %>" class="btn btn-warning btn-sm">Check Out & Pay</a>
                        <% } %>
                    </td>
                </tr>
            <% }); %>
        </tbody>
    </table>
<% } %>

<%- include('../partials/footer') %>